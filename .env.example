# ============================================
# Syntara — Environment Variables
# ============================================
# Copy this file to .env and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-random-32-char-secret

# Database (Neon or local)
DATABASE_URL=postgresql://user:password@host:5432/syntara?sslmode=require

# Auth
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Ollama — text generation + embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.2:latest
OLLAMA_REWRITE_MODEL=llama3.2:latest
OLLAMA_SUMMARY_MODEL=llama3.2:latest
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text:latest

# Nano Banana — image generation / editing
NANO_BANANA_API_KEY=your-nano-banana-api-key
NANO_BANANA_BASE_URL=https://api.nanobanana.io/v1

# Instagram / Meta
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# Cloudinary — image storage & CDN (required for Instagram publishing)
# Sign up free at https://cloudinary.com — 25 credits/month on free tier
# 1. Dashboard → copy your "Cloud Name"
# 2. Settings → Upload → Add Upload Preset (Signing Mode: Unsigned)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_PRESET=syntara

# Storage (S3-compatible — optional, overrides Cloudinary if set)
STORAGE_BUCKET=syntara-assets
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com

# Encryption (for social tokens — generate 32-byte hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Background Jobs
JOB_SECRET=your-job-secret
REDIS_URL=redis://localhost:6379

# Cron (for Next.js cron routes)
CRON_SECRET=your-cron-secret
