// This is your Prisma schema file

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Platform {
  INSTAGRAM
  WHATSAPP
}

enum ContentType {
  FEED_POST
  CAROUSEL
  REEL
  STORY
}

enum DraftStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum PublishStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  SCHEDULED
}

enum TonePreset {
  PROFESSIONAL
  CASUAL
  BOLD
  SAFE
  PREMIUM
  PLAYFUL
  EMPOWERING
  MINIMAL
}

enum MediaType {
  IMAGE
  VIDEO
  CAROUSEL
}

enum AssetSource {
  UPLOAD
  GENERATED
  INSTAGRAM
  URL
}

enum ImageJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SectionType {
  CAPTION
  HOOK
  BODY
  CTA
  HASHTAGS
  SLIDE_TEXT
  FRAME_COPY
  SCRIPT
  SHOT_LIST
  THUMBNAIL_IDEA
  VISUAL_PROMPT
}

enum AccountStatus {
  ACTIVE
  RATE_LIMITED
  DISCONNECTED
  PENDING_REVIEW
  UNSUPPORTED_ACCOUNT_TYPE
}

enum InsightType {
  TOP_HOOK
  TOP_CTA
  TOP_FORMAT
  CONTENT_GAP
  POST_READINESS
  BRAND_ALIGNMENT
  DUPLICATE_WARNING
  MISSING_MEDIA
  WEAK_HOOK
  OVERLENGTH
  VISUAL_MISMATCH
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  AI_DRAFT
  APPROVED
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum LeadStatus {
  NEW_INQUIRY
  QUALIFYING
  OFFER_SENT
  FOLLOW_UP_PENDING
  READY_TO_BUY
  WON
  LOST
}

enum TaskType {
  FOLLOW_UP
  CALL
  QUOTE
  BOOKING
  MEETING
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResponseZone {
  GREEN
  YELLOW
  RED
}

enum ChannelType {
  INSTAGRAM
  WHATSAPP
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  SKIPPED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces  Workspace[]
  accounts    SocialAccount[]
  usageEvents UsageEvent[]
  workspaceMemberships WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  brands         BrandProfile[]
  drafts         Draft[]
  mediaAssets    MediaAsset[]
  scheduledPosts ScheduledPost[]
  analytics      AnalyticsSnapshot[]
  socialAccounts SocialAccount[]
  settings       WorkspaceSettings?
  members        WorkspaceMember[]
  contacts       Contact[]
  conversations  Conversation[]
  messages       Message[]
  leads         Lead[]
  pipelineStages PipelineStage[]
  tasks         Task[]
  savedReplies  SavedReply[]
  leadActivities LeadActivity[]
  channelWebhookEvents ChannelWebhookEvent[]
}

model BrandProfile {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  audienceDesc    String?
  voiceGuidance   String?
  styleKeywords   String[]
  bannedPhrases   String[]
  bannedClaims    String[]
  ctaPreferences  String?
  visualStyle       String?
  preferredLanguage String   @default("en")
  dialect           String?
  colorReferences String[]
  referenceUrls   String[]
  negativePrompts String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  drafts         Draft[]
  contentSources ContentSource[]
}

model SocialAccount {
  id              String        @id @default(cuid())
  userId          String?
  workspaceId     String
  platform        Platform      @default(INSTAGRAM)
  channel         ChannelType   @default(INSTAGRAM)
  instagramId     String?       @unique
  username        String?
  displayName     String?
  profileImageUrl String?
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  accountStatus   AccountStatus @default(PENDING_REVIEW)
  isProfessional  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishAttempts PublishAttempt[]
  analytics       AnalyticsSnapshot[]

  @@index([workspaceId, channel])
}

model ContentSource {
  id           String   @id @default(cuid())
  brandId      String
  sourceType   String // "topic" | "note" | "product_update" | "launch_update" | "promo_offer" | "url" | "upload" | "brief" | "draft_duplication"
  rawContent   String?
  url          String?
  uploadedUrls String[]
  metadata     Json? // extracted OG data, etc.
  createdAt    DateTime @default(now())

  brand BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)
  draft Draft?
}

model Draft {
  id          String      @id @default(cuid())
  workspaceId String
  brandId     String
  sourceId    String?     @unique
  contentType ContentType
  status      DraftStatus @default(DRAFT)
  tone        TonePreset  @default(CASUAL)

  // Feed post fields
  caption         String?
  captionVariants String[] // stored as JSON array of strings
  cta             String?
  hashtags        String[]
  altText         String?

  // Reel fields
  reelHook     String?
  reelScript   String?
  reelShotList String[]
  reelCaption  String?

  // Story fields
  storyFrames Json? // [{frameNumber, copy, stickerSuggestions, cta}]

  // Scoring
  readinessScore    Int? // 0–100
  brandScore        Int? // 0–100
  completenessScore Int? // 0–100
  viralScore       Int? // 0–100 AI viral score
  duplicateFlag     Boolean @default(false)

  // Metadata
  meta        Json? // {instagramId, permalink, etc.}
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand         BrandProfile     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  source        ContentSource?   @relation(fields: [sourceId], references: [id])
  sections      DraftSection[]
  variants      DraftVariant[]
  mediaAssets   DraftMedia[]
  scheduledPost ScheduledPost?
  insights      ContentInsight[]
  viralAnalysis ViralAnalysis?
  media         MediaAsset[]
}

model DraftVariant {
  id         String   @id @default(cuid())
  draftId    String
  name       String // "A", "B", "C" or descriptive
  isSelected Boolean  @default(false)
  data       Json // full structured copy variant
  viralScore Int? // 0–100 viral score computed at generation time
  createdAt  DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model DraftSection {
  id          String      @id @default(cuid())
  draftId     String
  sectionType SectionType
  sortOrder   Int
  content     String?
  promptUsed  String? // original Ollama prompt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id           String      @id @default(cuid())
  workspaceId  String
  draftId      String?
  instagramId  String?     @unique
  assetSource  AssetSource
  mediaType    MediaType   @default(IMAGE)
  url          String
  thumbnailUrl String?
  width        Int?
  height       Int?
  mimeType     String?
  altText      String?
  meta         Json? // Instagram media metadata
  createdAt    DateTime    @default(now())

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  draft          Draft?               @relation(fields: [draftId], references: [id])
  imageJobs      ImageGenerationJob[]
  promptVersions PromptVersion[]
  DraftMedia     DraftMedia[]
}

model DraftMedia {
  draftId   String
  assetId   String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  draft Draft      @relation(fields: [draftId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([draftId, assetId])
}

model ImageGenerationJob {
  id            String         @id @default(cuid())
  assetId       String?
  promptId      String?
  status        ImageJobStatus @default(PENDING)
  providerJobId String? // Nano Banana job ID
  requestedAt   DateTime       @default(now())
  completedAt   DateTime?
  errorMessage  String?
  requestMeta   Json? // {prompt, model, size, style}
  responseMeta  Json? // {url, dimensions, format}

  asset  MediaAsset?    @relation(fields: [assetId], references: [id])
  prompt PromptVersion? @relation(fields: [promptId], references: [id])
}

model PromptVersion {
  id               String   @id @default(cuid())
  assetId          String?
  draftSectionId   String?
  provider         String // "nanobanana" | "ollama"
  prompt           String
  normalizedPrompt String?
  modelUsed        String?
  parameters       Json? // size, style, seed, etc.
  outputUrl        String?
  outputMeta       Json?
  createdAt        DateTime @default(now())

  asset     MediaAsset?          @relation(fields: [assetId], references: [id])
  imageJobs ImageGenerationJob[]
}

model ScheduledPost {
  id            String        @id @default(cuid())
  draftId       String        @unique
  variantId     String?
  workspaceId   String
  scheduledAt   DateTime
  publishStatus PublishStatus @default(SCHEDULED)
  instagramId   String?
  permalink     String?
  retryCount    Int           @default(0)
  lastError     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  draft           Draft            @relation(fields: [draftId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishAttempts PublishAttempt[]
}

model PublishAttempt {
  id              String        @id @default(cuid())
  scheduledPostId String?
  socialAccountId String?
  status          PublishStatus
  instagramId     String?
  permalink       String?
  errorCode       String?
  errorMessage    String?
  attemptedAt     DateTime      @default(now())

  scheduledPost ScheduledPost? @relation(fields: [scheduledPostId], references: [id])
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id])
}

model AnalyticsSnapshot {
  id               String       @id @default(cuid())
  socialAccountId  String
  workspaceId      String
  instagramMediaId String?      @unique
  igShortCode      String? // Instagram shortcode for URL construction
  postUrl          String?
  postType         ContentType?
  caption          String?
  publishedAt      DateTime?
  likesCount       Int          @default(0)
  commentsCount    Int          @default(0)
  savesCount       Int          @default(0)
  sharesCount      Int          @default(0)
  impressions      Int?
  reach            Int?
  plays            Int?
  followerCount    Int?
  syncedAt         DateTime     @default(now())
  isDeleted       Boolean      @default(false) // true when post is deleted from Instagram

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, syncedAt])
}

model ContentInsight {
  id          String      @id @default(cuid())
  draftId     String
  insightType InsightType
  severity    String // "info" | "warning" | "critical"
  message     String
  data        Json?
  createdAt   DateTime    @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model ViralAnalysis {
  id        String   @id @default(cuid())
  draftId   String   @unique
  overallScore Int    // 0–100 viral score

  hookStrength    Int  // 0–10
  clarity         Int  // 0–10
  originality     Int  // 0–10
  emotionalPull   Int  // 0–10
  shareability    Int  // 0–10
  saveWorthiness  Int  // 0–10
  commentTrigger  Int  // 0–10
  audienceFit     Int  // 0–10
  formatFit       Int  // 0–10

  weaknesses         String[] // specific weaknesses in the caption
  rewrittenCaption  String? // complete rewritten caption — hook + body + CTA + hashtags, ready to publish
  rewrittenCta      String? // rewritten call-to-action
  viralSummary     String? // one-paragraph summary

  modelUsed    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member") // "owner" | "member" | "viewer"
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedLeads Lead[]
  conversations Conversation[]
  tasks     Task[]

  @@unique([workspaceId, userId])
}

model Contact {
  id             String   @id @default(cuid())
  workspaceId    String
  instagramId    String?  @unique
  whatsappId     String?
  username       String?
  displayName    String?
  profileImageUrl String?
  bio            String?
  email          String?
  phone          String?
  location       String?
  isFollowing    Boolean  @default(false)
  is_verified    Boolean  @default(false)
  follower_count Int      @default(0)
  following_count Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  leads         Lead[]
  messages      Message[]

  @@index([workspaceId])
  @@index([instagramId])
}

model Conversation {
  id              String             @id @default(cuid())
  workspaceId      String
  contactId       String
  channel         ChannelType        @default(INSTAGRAM)
  platform_conversation_id String?  @unique
  status          ConversationStatus @default(OPEN)
  assignedToId    String?
  leadId          String?
  last_message_at DateTime?
  last_message_preview String?
  unread_count    Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo   WorkspaceMember? @relation(fields: [assignedToId], references: [id])
  lead         Lead?          @relation(fields: [leadId], references: [id])
  messages     Message[]
  leadActivities LeadActivity[]

  @@index([workspaceId, status])
  @@index([contactId])
}

model Message {
  id              String         @id @default(cuid())
  workspaceId     String
  conversationId  String
  contactId       String
  direction       MessageDirection
  content         String?
  raw_payload     Json?
  ai_intent       String?
  ai_confidence   Float?
  ai_suggestion   String?
  response_zone   ResponseZone?
  status          MessageStatus  @default(PENDING)
  instagram_media_id String?
  message_id      String?        @unique
  createdAt       DateTime       @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
}

model Lead {
  id              String     @id @default(cuid())
  workspaceId     String
  contactId       String
  conversationId  String?
  pipelineStageId String?
  status          LeadStatus @default(NEW_INQUIRY)
  first_name      String?
  last_name       String?
  email           String?
  phone           String?
  company         String?
  notes           String?
  estimated_value Decimal?   @db.Decimal(10, 2)
  currency        String     @default("OMR")
  source          String?
  utm_source      String?
  utm_medium      String?
  utm_campaign    String?
  assignedToId    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  closedAt        DateTime?

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact       Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipelineStage PipelineStage?  @relation(fields: [pipelineStageId], references: [id])
  assignedTo    WorkspaceMember? @relation(fields: [assignedToId], references: [id])
  tasks         Task[]
  activities    LeadActivity[]
  conversations Conversation[]

  @@index([workspaceId, status])
  @@index([contactId])
}

model PipelineStage {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  position    Int
  color       String     @default("#6366f1")
  is_default  Boolean    @default(false)
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@unique([workspaceId, position])
  @@index([workspaceId])
}

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  leadId     String?
  assignedToId String?
  title       String
  description String?
  type        TaskType     @default(FOLLOW_UP)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead      Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo WorkspaceMember? @relation(fields: [assignedToId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dueDate])
  @@index([assignedToId, completedAt])
}

model SavedReply {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String
  category    String   @default("general")
  shortcut    String?  @unique
  response_zone ResponseZone @default(GREEN)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, is_active])
}

model LeadActivity {
  id              String   @id @default(cuid())
  workspaceId     String
  leadId          String
  conversationId  String?
  type            String
  description     String
  metadata        Json?
  createdAt       DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([leadId, createdAt])
}

model ChannelWebhookEvent {
  id              String            @id @default(cuid())
  workspaceId     String
  platform        Platform          @default(INSTAGRAM)
  event_type      String
  event_id        String?           @unique
  raw_payload     Json
  delivery_attempt Int               @default(0)
  status          WebhookEventStatus @default(RECEIVED)
  error_message   String?
  processed_at    DateTime?
  createdAt       DateTime          @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([event_id])
}

model UsageEvent {
  id         String   @id @default(cuid())
  userId     String
  eventType  String // "ollama_generation" | "image_generation" | "publish" | "login"
  model      String?
  durationMs Int?
  success    Boolean
  errorMsg   String?
  meta       Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceSettings {
  id                    String  @id @default(cuid())
  workspaceId           String  @unique
  ollamaBaseUrl        String  @default("http://localhost:11434")
  ollamaTextModel      String  @default("llama3.2:latest")
  ollamaEmbeddingsModel String @default("nomic-embed-text:latest")
  nanobananaApiKey     String?
  nanobananaBaseUrl    String  @default("https://api.nanobanana.io/v1")
  // Growth OS
  autoReplyEnabled     Boolean @default(false)
  autoReplyGreenOnly   Boolean @default(true)
  ollamaTextModelGrowthOs String @default("llama3.2:latest")
  businessFacts        String? // free-text business context for Ollama
  timezone             String  @default("Asia/Muscat")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
